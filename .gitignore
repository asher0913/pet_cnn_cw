predictions.csv

# Individual training checkpoints are far too big to push to a
# standard git remote (~10 MB each for custom, ~45 MB for ResNet-18).
# Only hand-picked weights for the submission should be committed,
# and those live under the dedicated ``weights/`` folder.
*.pt
*.pth
!weights/*.pt
!weights/*.pth
